---
const { name, image, favorite_emoji, github_permalink, github_profile, codepen_profile} = Astro.props;
const slug = name.toLowerCase().replace(/\s+/g, "-");
---

<figure class="card">
  <img src={image} alt={name} loading="lazy" />
  <figcaption class="card-name">
    <a href={`/${slug}`}><span class="card-emoji">{favorite_emoji}</span> {name}</a>
  </figcaption>
  <nav class="card-links">
    <a href={github_permalink} target="_blank" rel="noopener">Portfolio</a>
    <a href={github_profile} target="_blank" rel="noopener">GitHub</a>
    <a href={codepen_profile} target="_blank" rel="noopener">CodePen</a>
  </nav>
</figure>



<style>
  .card {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 28px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    background: #ffffff;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.14);
    border-color: rgba(15, 23, 42, 0.12);
  }

  .card img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    display: block;
    border-radius: 20px;
  }

  .card-name a {
    text-decoration: none;
    color: #111827;
    font-family: 'Satoshi', sans-serif;
    font-weight: 800;
    font-size: 1.4rem;
    line-height: 1.1;
  }

  .card-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .card-emoji {
    font-size: 1.2rem;
  }

  .card-links {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    margin-top: 0.75rem;
    overflow-x: auto;
  }

  .card-links a {
    background: #b7132e;
    font-size: 0.75rem;
    font-family: 'Satoshi', sans-serif;
    padding: 0.35rem 0.75rem;
    min-width: 0;
    text-decoration: none;
    color: white;
    
    transition: background 180ms ease, transform 180ms ease;
  }

  .card-links a:hover {
    background: #8e1024;
    transform: translateY(-1px);
    color: white;
  }
</style>
